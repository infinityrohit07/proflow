# MongoDB Atlas Connection URI
MONGO_URI="your-mongodb-atlas-uri"

# JWT Authentication Secrets
ACCESS_TOKEN_SECRET="your-jwt-access-token-secret"
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_SECRET="your-jwt-refresh-token-secret"
REFRESH_TOKEN_EXPIRY="10d"

# Cloudinary Integration (Image Uploads)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Gemini AI API Key
GEMINI_API_KEY="your-gemini-api-key"

# Google OAuth Integration
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# SMTP Email Configuration (Optional - Falls back to console log if blank)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user@gmail.com"
SMTP_PASS="your-smtp-app-password"

# Public Application URL (Used for CORS and redirects)
APP_URL="http://localhost:3000"
